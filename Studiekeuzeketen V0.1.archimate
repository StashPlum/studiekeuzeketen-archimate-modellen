            <bounds x="222" y="270" width="193" height="49"/>
          </child>
          <child xsi:type="archimate:DiagramObject" id="id-a3837a50e9f84ca6bdb97fb433630e03" archimateElement="id-e1d4e4f150df4368a99060b3ccc7e760">
            <bounds x="156" y="96" width="157" height="49"/>
